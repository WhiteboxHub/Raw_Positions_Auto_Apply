# SmartApply Environment Variables
# Copy this file to .env and fill in your credentials
# .env should NEVER be committed to version control

# Gmail SMTP Credentials (if using SMTP)
# Use App Password if you have 2FA enabled, NOT your account password
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Gmail API Credentials (if using Gmail API)
# Path to your OAuth2 credentials JSON file (download from Google Cloud Console)
GMAIL_API_CREDENTIALS_PATH=credentials.json

# Optional: Ollama Custom Settings (can override config.yaml)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Optional: Custom CSV Input Directory
# INPUT_DIR=custom_input_folder

# Optional: Custom Resume Paths
# RESUME_JSON=custom_resume/resume.json
# RESUME_PDF=custom_resume/resume.pdf
